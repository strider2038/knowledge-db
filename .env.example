# Путь к корню базы знаний (обязателен для kb-server)
KB_DATA_PATH=/path/to/knowledge-base

# Путь к директории для загрузки файлов (обязателен для kb-server)
KB_UPLOADS_DIR=/path/to/uploads

# Токен Telegram-бота (опционально, без него бот не запускается)
TELEGRAM_TOKEN=

# Адрес HTTP-сервера (по умолчанию :8080)
KB_HTTP_ADDR=:8080

# CORS origin для dev (Vite на :5173). Пусто — без CORS (production).
ALLOWED_CORS_ORIGIN=http://localhost:5173

# Публичный URL веб-интерфейса (для ссылок из Telegram и редиректа после Google OAuth; без завершающего /)
KB_PUBLIC_WEB_BASE_URL=

# Опциональная сессионная авторизация. Ровно один режим: (A) пароль или (B) Google OAuth — взаимоисключающие.
# Пароль: задайте оба KB_LOGIN и KB_PASSWORD, без переменных Google ниже.
KB_LOGIN=
KB_PASSWORD=

# Google OAuth 2.0: полный набор + пустые KB_LOGIN/KB_PASSWORD. См. design в openspec/changes/google-oauth-web-auth
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
# URL callback как в Google Cloud Console (часто .../api/auth/google/callback)
KB_GOOGLE_OAUTH_REDIRECT_URL=
KB_OAUTH_STATE_SECRET=
# Разрешённые email (через запятой), сравнение без регистра
KB_AUTH_ALLOWED_EMAILS=
# TTL сессии (по умолчанию 8h)
KB_SESSION_TTL=8h

# OpenSpec: openspec/changes/google-oauth-web-auth (документация и план)
