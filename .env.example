# Путь к корню базы знаний (обязателен для kb serve)
KB_DATA_PATH=/path/to/knowledge-base

# Путь к директории для загрузки файлов (обязателен для kb serve)
KB_UPLOADS_DIR=/path/to/uploads

# Отключить git-интеграцию (commit/sync) для базы знаний
KB_GIT_DISABLED=false

# Интервал фонового git sync (если git не отключён)
GIT_SYNC_INTERVAL=5m

# Автоперевод контента при ingestion
KB_AUTO_TRANSLATE=true

# Раскрытие URL в тексте и annotation после LLM-обработки
KB_INGEST_EXPAND_URLS=true

# Токен Telegram-бота (опционально, без него бот не запускается)
TELEGRAM_TOKEN=

# Ограничить доступ к боту конкретным Telegram user id (0 — без ограничения)
TELEGRAM_OWNER_ID=0

# Адрес HTTP-сервера (по умолчанию :8080)
KB_HTTP_ADDR=:8080

# API-ключ для MCP endpoint /api/mcp (Bearer). Пусто/не задано — MCP отключён.
KB_MCP_API_KEY=
# API-ключ для debug MCP endpoint /api/mcp/debug (Bearer). Пусто/не задано — debug MCP отключён.
KB_MCP_DEBUG_API_KEY=
# Включить запись сырых Telegram update payload в .kb/telegram-raw/*.ndjson
KB_TELEGRAM_RAW_LOG_ENABLED=false

# CORS origin для dev (Vite на :5173). Пусто — без CORS (production).
ALLOWED_CORS_ORIGIN=http://localhost:5173

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# Публичный URL веб-интерфейса (для ссылок из Telegram и редиректа после Google OAuth; без завершающего /)
KB_PUBLIC_WEB_BASE_URL=

# Jina API key для внешних API, где требуется
JINA_API_KEY=

# LLM-конфигурация (OpenAI-совместимый API) для ingestion/обработки
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o

# Опциональная сессионная авторизация. Ровно один режим: (A) пароль или (B) Google OAuth — взаимоисключающие.
# Пароль: задайте оба KB_LOGIN и KB_PASSWORD, без переменных Google ниже.
KB_LOGIN=
KB_PASSWORD=

# Google OAuth 2.0: полный набор + пустые KB_LOGIN/KB_PASSWORD. См. design в openspec/changes/google-oauth-web-auth
KB_GOOGLE_OAUTH_CLIENT_ID=
KB_GOOGLE_OAUTH_CLIENT_SECRET=
# URL callback как в Google Cloud Console (часто .../api/auth/google/callback)
KB_GOOGLE_OAUTH_REDIRECT_URL=
KB_OAUTH_STATE_SECRET=
# Разрешённые email (через запятой), сравнение без регистра
KB_AUTH_ALLOWED_EMAILS=
# TTL сессии (по умолчанию 8h)
KB_SESSION_TTL=8h

# Эмбеддинги и RAG (опционально)
KB_EMBEDDING_ENABLED=false
KB_EMBEDDING_API_KEY=
KB_EMBEDDING_API_URL=
KB_EMBEDDING_MODEL=text-embedding-3-small

# Чат-модель для RAG (опционально). Если KB_CHAT_API_URL пуст, используется KB_EMBEDDING_API_URL.
KB_CHAT_MODEL=
KB_CHAT_API_URL=
KB_CHAT_API_KEY=

# Переписывание поискового запроса перед векторным поиском
KB_SEARCH_REWRITE_ENABLED=true

# Ограничение частоты запросов к embedding API
KB_EMBEDDING_RATE_LIMIT=1s

# OpenSpec: openspec/changes/google-oauth-web-auth (документация и план)
